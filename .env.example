# ==============================================
# NEBULA AI - ENVIRONMENT VARIABLES
# ==============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ==============================================
# SUPABASE CONFIGURATION
# ==============================================
# Get these from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase Project ID (for type generation)
SUPABASE_PROJECT_ID=your-project-id

# ==============================================
# MONGODB CONFIGURATION
# ==============================================
# Get from: https://cloud.mongodb.com/
# Format: mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/nebula-ai?retryWrites=true&w=majority

# Database name
MONGODB_DB_NAME=nebula-ai

# ==============================================
# AWS CONFIGURATION
# ==============================================
# IAM User credentials with permissions for:
# - Bedrock (invoke model)
# - Rekognition (detect labels, detect text, detect faces)
# - Rekognition Video (start/get label detection)
# - S3 (put/get object, generate presigned URLs)
# - Transcribe (start/get transcription job)

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# S3 Bucket for media uploads
AWS_S3_BUCKET_NAME=nebula-ai-uploads
AWS_S3_REGION=us-east-1

# Bedrock Model IDs
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
AWS_BEDROCK_MODEL_REGION=us-east-1

# ==============================================
# GROQ AI CONFIGURATION (FALLBACK PROVIDER)
# ==============================================
# Get your API key from: https://console.groq.com/keys
# Groq provides fast inference with Llama3 models
# If AWS Bedrock is unavailable, Groq will be used as fallback
# Model used: llama3-8b-8192
GROQ_API_KEY=your-groq-api-key-here

# ==============================================
# APPLICATION CONFIGURATION
# ==============================================
# Base URL for your application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment
NODE_ENV=development

# ==============================================
# AUTHENTICATION PROVIDER
# ==============================================
# Options: 'cognito' | 'supabase'
# Default: 'supabase'
# Set to 'cognito' to use AWS Cognito JWT authentication
AUTH_PROVIDER=supabase

# AWS Cognito Configuration (only needed if AUTH_PROVIDER=cognito)
# COGNITO_REGION=us-east-1
# COGNITO_USER_POOL_ID=us-east-1_cgTtku27r

# ==============================================
# SECURITY
# ==============================================
# Generate a random string for JWT signing (if needed)
# You can use: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Encryption key for sensitive data (wellness logs)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-encryption-key-64-characters-hex

# ==============================================
# GUARDIAN MODE
# ==============================================
# Secret key for internal Guardian Mode escalation endpoint
# Generate with: openssl rand -hex 32
# Used in x-service-key header by background services
GUARDIAN_SERVICE_KEY=your-guardian-service-key-here

# AWS SES (Simple Email Service) — used by Guardian Mode email notifications
# The IAM user must have ses:SendEmail permission
# AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY above are reused for SES
# Sender address must be verified in AWS SES (sandbox: both sender AND recipient must be verified)
AWS_SES_FROM_EMAIL=noreply@nebula-ai.com
AWS_SES_FROM_NAME=Nebula AI
# Override SES region if different from AWS_REGION (optional)
# AWS_SES_REGION=us-east-1

# Twilio SMS — used by Guardian Mode SMS notifications (Stage 2+ escalations)
# Get these from: https://console.twilio.com/
# TWILIO_ACCOUNT_SID: found on the Twilio Console dashboard
# TWILIO_AUTH_TOKEN: found on the Twilio Console dashboard (keep secret)
# TWILIO_FROM_NUMBER: a Twilio phone number in E.164 format (e.g. +15551234567)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
TWILIO_FROM_NUMBER=+15551234567

# ==============================================
# FEATURE FLAGS
# ==============================================
# Enable/disable features during development
NEXT_PUBLIC_ENABLE_VOICE=true
NEXT_PUBLIC_ENABLE_FILE_UPLOAD=true
NEXT_PUBLIC_ENABLE_PROJECT_MEMORY=true

# ==============================================
# RATE LIMITING (Optional - for production)
# ==============================================
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# ==============================================
# LOGGING (Optional)
# ==============================================
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true
